# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica
VITE_ALLOWED_EMAIL_DOMAINS=empresa.com,cliente.com

# Opcional. Se vazio, o app usa automaticamente origin + base do Vite.
# Em producao no GitHub Pages:
# VITE_AUTH_REDIRECT_URL=https://cnkautmblabs.github.io/stark-hub/

# Azure DevOps e Slack devem ser preenchidos pelo usuario em Configuracoes.
# Nao coloque PAT, webhook, org real, projeto real ou time real neste arquivo.

# Opcional. E-mail que pode alternar o tipo do Resumo executivo (Dev/QA/Gestao)
# na Home independente do proprio nivel de acesso. Deixe vazio para desativar.
# Definido apenas em .env.local (nunca commitado) para nao expor e-mail pessoal no bundle.
VITE_ADMIN_EMAIL=

